+  blockingIO : Maybe Bool
+
+export
+FromJSON ProcessTask where
+  fromJSON = withObject "ProcessTask" $ \o =>
+    [| MKProcessTask (field      o "name")
+                     (field      o "path")
+                     (field      o "args")
+                     (field      o "timeout")
+                     (field      o "logFile")
+                     (fieldMaybe o "blockingIO") |]
 
