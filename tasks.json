[
  {
    "name": "List Root Directory",
    "path": "ls",
    "args": ["-la", "./"],
    "timeout": 2,
    "logFile": "logs/root_dir.log",
    "blockingIO": false
  },
  {
    "name": "Quick Sleep",
    "path": "sleep",
    "args": ["0.5"],
    "timeout": 1,
    "logFile": "logs/timeout_error.log",
    "blockingIO": false
  },
  {
    "name": "Colored Output",
    "path": "ls",
    "args": ["--color=always", "-la", "/"],
    "timeout": 2,
    "logFile": "logs/colored.log",
    "blockingIO": false
  },
  {
    "name": "Watch",
    "path": "cat",
    "args": ["/dev/urandom", "|", "xxd"],
    "timeout": 30,
    "logFile": null,
    "blockingIO": false
  },
  {
    "name": "Timed Out Task",
    "path": "sleep",
    "args": ["5"],
    "timeout": 1,
    "logFile": null,
    "blockingIO": false
  },
  {
    "name": "ansible",
    "path": "ansible-playbook",
    "args": ["test/playbook.yml"],
    "timeout": 300,
    "logFile": null,
    "blockingIO": true
  },
  {
    "name": "Missing Binary Test",
    "path": "/usr/bin/not-exist",
    "args": [],
    "timeout": 5,
    "logFile": null,
    "blockingIO": false
  }
]
