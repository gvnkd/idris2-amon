{
  "config": {
    "batchName": "Test Suite",
    "maxWorkers": 3
  },
  "Test Suite": {
    "Quick Sleep": {
      "path": "sleep",
      "args": ["0.5"],
      "timeout": 1,
      "logFile": "logs/quick_sleep.log",
      "blockingIO": false
    },
    "Colored Output": {
      "path": "ls",
      "args": ["--color=always", "-la", "/"],
      "timeout": 2,
      "logFile": "logs/colored.log",
      "blockingIO": false
    },
    "Timed Out Task": {
      "path": "sleep",
      "args": ["5"],
      "timeout": 1,
      "logFile": "logs/timeout.log",
      "blockingIO": false
    },
    "Failing Command": {
      "path": "false",
      "args": [],
      "timeout": 2,
      "logFile": "logs/failing.log",
      "blockingIO": false
    },
    "Missing Binary Test": {
      "path": "/usr/bin/not-exist",
      "args": [],
      "timeout": 5,
      "logFile": "logs/missing.log",
      "blockingIO": false
    },
    "Echo Test": {
      "path": "echo",
      "args": ["Hello from echo task"],
      "timeout": 2,
      "logFile": "logs/echo.log",
      "blockingIO": false
    },
    "Ansible": {
      "path": "ansible-playbook",
      "args": ["-i", "localhost,", "test/playbook.yml"],
      "timeout": 30,
      "logFile": "logs/ansible.log",
      "blockingIO": false
    },
    "Watch": {
      "path": "sh",
      "args": ["-c", "cat /dev/urandom | xxd | head -n 20"],
      "timeout": 5,
      "logFile": "logs/watch.log",
      "blockingIO": false
    }
  }
}
