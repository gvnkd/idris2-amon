[
  {
    "name": "Ansible",
    "path": "ansible-playbook",
    "args": ["test/playbook.yml"],
    "timeout": 20,
    "logFile": "logs/ansible.log",
    "blockingIO": true
  },
  {
    "name": "Quick Sleep",
    "path": "sleep",
    "args": ["0.5"],
    "timeout": 1,
    "logFile": "logs/quick_sleep.log",
    "blockingIO": false
  },
  {
    "name": "Colored Output",
    "path": "ls",
    "args": ["--color=always", "-la", "/"],
    "timeout": 2,
    "logFile": "logs/colored.log",
    "blockingIO": false
  },
  {
    "name": "Watch",
    "path": "./watch.sh",
    "args": [ ],
    "timeout": 30,
    "logFile": null,
    "blockingIO": false
  },
  {
    "name": "Timed Out Task",
    "path": "sleep",
    "args": ["5"],
    "timeout": 1,
    "logFile": "logs/timeout.log",
    "blockingIO": false
  },
  {
    "name": "Missing Binary Test",
    "path": "/usr/bin/not-exist",
    "args": [],
    "timeout": 5,
    "logFile": "logs/missing.log",
    "blockingIO": false
  }
]
